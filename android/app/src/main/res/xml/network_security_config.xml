<?xml version="1.0" encoding="utf-8"?>
<!--
  Autorise le trafic HTTP en clair uniquement vers la boucle locale (127.0.0.1)
  et le réseau local, car l'app parle en HTTP au serveur embarqué de Watchtower
  (voir lib/data/watchtower_client.dart) qui tourne sur le même appareil.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
